{
  "entities": {
    "User": {
      "title": "User",
      "description": "A makerspace user or admin",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["member", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "photoURL": { "type": "string", "format": "uri" },
        "libraryCardNumber": { "type": "string" }
      },
      "required": ["name", "email", "role", "createdAt"]
    },
    "Qualification": {
      "title": "Qualification",
      "description": "A user's qualification for specific equipment",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "equipmentId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active"] },
        "acquiredAt": { "type": "string", "format": "date-time" },
        "signedOffBy": { "type": "string", "description": "Admin UID who signed off" }
      },
      "required": ["userId", "equipmentId", "status"]
    },
    "RoomLog": {
      "title": "RoomLog",
      "description": "Log of a user entering/leaving the makerspace",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "signInTime": { "type": "string", "format": "date-time" },
        "signOutTime": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "signInTime"]
    },
    "UsageLog": {
      "title": "UsageLog",
      "description": "Log of equipment usage",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "equipmentId": { "type": "string" },
        "amount": { "type": "number" },
        "unit": { "type": "string" },
        "loggedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "equipmentId", "amount", "unit", "loggedAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback or consumable report",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["consumable", "general", "issue"] },
        "status": { "type": "string", "enum": ["new", "in-progress", "resolved", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "message", "type", "status", "createdAt"]
    },
    "Instruction": {
      "title": "Instruction",
      "description": "Step-by-step instruction manual for equipment",
      "type": "object",
      "properties": {
        "equipmentId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["equipmentId", "title", "content", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A project created by a user to share on the board",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string", "format": "uri" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "equipmentUsed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "likes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "authorName", "title", "description", "imageUrl", "likes", "createdAt"]
    },
    "PrintJob": {
      "title": "PrintJob",
      "description": "A document/job uploaded by a user for processing",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "fileName": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileData": { "type": "string", "description": "Base64 encoded file data for small files" },
        "driveFileId": { "type": "string", "description": "Google Drive file ID" },
        "filamentColor": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "ready", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "fileName", "status", "createdAt"]
    },
    "AppConfig": {
      "title": "AppConfig",
      "description": "Global application configuration, such as Google Drive tokens",
      "type": "object",
      "properties": {
        "tokens": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tokens", "updatedAt"]
    },
    "Equipment": {
      "title": "Equipment",
      "description": "Makerspace equipment details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "quiz": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "answer": { "type": "number" }
            }
          }
        },
        "slides": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "content": { "type": "string" },
              "imageUrl": { "type": "string", "format": "uri" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "createdAt"]
    },
    "InductionBooking": {
      "title": "InductionBooking",
      "description": "A booking for an in-person induction",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "equipmentId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "equipmentId", "date", "status", "createdAt"]
    },
    "DesignTool": {
      "title": "DesignTool",
      "description": "A design tool or generator",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "type": { "type": "string", "enum": ["external", "react", "iframe"] },
        "imageUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "url", "type", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users collection"
    },
    "qualifications/{qualificationId}": {
      "schema": { "$ref": "#/entities/Qualification" },
      "description": "Qualifications collection"
    },
    "room_logs/{logId}": {
      "schema": { "$ref": "#/entities/RoomLog" },
      "description": "Room logs collection"
    },
    "usage_logs/{logId}": {
      "schema": { "$ref": "#/entities/UsageLog" },
      "description": "Usage logs collection"
    },
    "feedback/{feedbackId}": {
      "schema": { "$ref": "#/entities/Feedback" },
      "description": "Feedback collection"
    },
    "instructions/{instructionId}": {
      "schema": { "$ref": "#/entities/Instruction" },
      "description": "Instructions collection"
    },
    "projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Projects collection"
    },
    "print_jobs/{jobId}": {
      "schema": { "$ref": "#/entities/PrintJob" },
      "description": "Print jobs collection"
    },
    "app_config/{configId}": {
      "schema": { "$ref": "#/entities/AppConfig" },
      "description": "Application configuration collection"
    },
    "equipment/{equipmentId}": {
      "schema": { "$ref": "#/entities/Equipment" },
      "description": "Equipment collection"
    },
    "induction_bookings/{bookingId}": {
      "schema": { "$ref": "#/entities/InductionBooking" },
      "description": "Induction bookings collection"
    }
  }
}
